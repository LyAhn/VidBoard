# Ollama (local LLM for planning + web search)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
# Required for Ollama's hosted web search API. Create a free account at https://ollama.com.
OLLAMA_API_KEY=your_ollama_api_key_here

# ComfyUI (local image generation)
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_WORKFLOW=flux2-klein
# Optional: use separate workflows for storyboard continuity.
# Start workflow should use the character/reference image only.
# End workflow should use both the character/reference image and generated Start frame.
# COMFYUI_START_WORKFLOW=flux2-klein-reference
# COMFYUI_END_WORKFLOW=flux2-klein-reference-img2img
COMFYUI_WORKFLOW_DIR=./comfyui

# ComfyUI timeouts (optional — defaults suit most local setups)
# How long to wait when checking ComfyUI is reachable / submitting a job (ms). Default: 10000
# COMFYUI_CONNECTION_TIMEOUT_MS=10000
# How long each individual history poll request may take before retrying (ms). Default: 60000
# Increase if ComfyUI's HTTP server is very slow to respond while loading a large model.
# COMFYUI_POLL_TIMEOUT_MS=60000
# Total wall-clock budget per image — covers cold model load + generation time (ms). Default: 900000 (15 min)
# COMFYUI_GENERATION_TIMEOUT_MS=900000
